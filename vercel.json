{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/whitepaper.js": {
      "includeFiles": "api/_content/whitepaper.md"
    },
    "api/whitepaper-lite.js": {
      "includeFiles": "api/_content/whitepaper-lite.md"
    }
  },
  "rewrites": [
    { "source": "/clipper", "destination": "/clipper/index.html" },
    { "source": "/whitepaper", "destination": "/api/whitepaper" },
    { "source": "/whitepaper-lite", "destination": "/api/whitepaper-lite" }
  ]
}
